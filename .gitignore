# Internal project workspace.
#
# Keep specifications, learning ledgers, scratch notes, and downloaded sidecars
# local-only unless a file is deliberately moved out of `.internal/`.
.internal/

# Rust build output.
/target/
**/*.rs.bk

# Editor and OS metadata.
.DS_Store
Thumbs.db
*.swp
*.swo
*~
*.tmp
*.bak

# Windows alternate data stream metadata copied into WSL/Linux workspaces.
*:Zone.Identifier

# Local environment and tool state.
.env
.env.*
!.env.example
.direnv/
.vscode/
.idea/

# Logs and generated reports.
*.log
coverage/
tarpaulin-report.html

# Native build artifacts.
build/
cmake-build-*/
*.o
*.a
*.so
*.dylib
*.dll
*.exe
